    "@types/node": "^26.1.1",
    "cross-env": "^10.1.0",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@faker-js/faker": "^10.5.0",
    "dotenv": "^17.4.2",
    "winston": "^3.19.0"
  }
}
